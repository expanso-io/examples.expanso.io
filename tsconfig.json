{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@site/*": ["./*"],
      "@/*": ["./src/*"]
    },
    "types": ["node", "@docusaurus/module-type-aliases"],
    "jsx": "react-jsx",
    "downlevelIteration": true
  },
  "include": ["src", "docs", "scripts"]
}
