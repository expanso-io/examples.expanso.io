{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://examples.expanso.io/tests/contracts/schemas/machine-journey-result-v1.schema.json",
  "title": "Expanso examples machine journey result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resultVersion",
    "contractId",
    "contractSha256",
    "subjectSha",
    "environmentId",
    "scorerVersion",
    "startedAt",
    "finishedAt",
    "trials"
  ],
  "properties": {
    "resultVersion": { "const": "1.0.0" },
    "contractId": { "const": "machine-journey-v1" },
    "contractSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "subjectSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "environmentId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]+$"
    },
    "scorerVersion": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "trials": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trialId", "persona", "seed", "tasks"],
        "properties": {
          "trialId": { "type": "string", "minLength": 1 },
          "persona": {
            "enum": ["evaluator", "practitioner", "existing-user-context"]
          },
          "seed": { "type": "string", "minLength": 1 },
          "tasks": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "taskId",
                "success",
                "elapsedMs",
                "wrongTurns",
                "abandonedRoutes",
                "confidence",
                "browserDevice",
                "scorerVersion",
                "assertions",
                "trace"
              ],
              "properties": {
                "taskId": { "type": "string", "minLength": 1 },
                "success": { "type": "boolean" },
                "elapsedMs": { "type": "number", "minimum": 0 },
                "wrongTurns": { "type": "integer", "minimum": 0 },
                "abandonedRoutes": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": { "type": "string", "minLength": 1 }
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "browserDevice": {
                  "enum": ["desktop", "tablet", "mobile"]
                },
                "scorerVersion": { "type": "string", "minLength": 1 },
                "assertions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["assertionId", "passed", "evidence"],
                    "properties": {
                      "assertionId": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
                      },
                      "passed": { "type": "boolean" },
                      "evidence": {
                        "type": "array",
                        "minItems": 1,
                        "uniqueItems": true,
                        "items": {
                          "enum": ["dom", "network", "screenshot", "commands"]
                        }
                      }
                    }
                  }
                },
                "trace": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["dom", "network", "screenshot", "commands"],
                  "properties": {
                    "dom": { "$ref": "#/$defs/artifactEvidence" },
                    "network": { "$ref": "#/$defs/artifactEvidence" },
                    "screenshot": { "$ref": "#/$defs/artifactEvidence" },
                    "commands": { "$ref": "#/$defs/artifactEvidence" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "artifactEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceVersion", "path", "sha256", "bytes"],
      "properties": {
        "evidenceVersion": { "const": "journey-artifact-v1" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "number", "minimum": 1 }
      }
    }
  }
}
