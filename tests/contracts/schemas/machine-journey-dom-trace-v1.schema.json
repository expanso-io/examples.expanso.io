{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://examples.expanso.io/tests/contracts/schemas/machine-journey-dom-trace-v1.schema.json",
  "title": "Expanso machine journey raw DOM trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceVersion",
    "contractId",
    "contractSha256",
    "subjectSha",
    "environmentId",
    "trialId",
    "taskId",
    "snapshots"
  ],
  "properties": {
    "traceVersion": { "const": "journey-dom-trace-v1" },
    "contractId": { "const": "machine-journey-v1" },
    "contractSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "subjectSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "environmentId": { "type": "string", "minLength": 3 },
    "trialId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "snapshots": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sequence",
          "url",
          "routeId",
          "familyId",
          "visibleText",
          "attributes"
        ],
        "properties": {
          "sequence": { "type": "integer", "minimum": 0 },
          "url": { "type": "string", "minLength": 1 },
          "routeId": { "type": "string", "minLength": 1 },
          "familyId": { "type": "string", "minLength": 1 },
          "visibleText": {
            "type": "array",
            "maxItems": 512,
            "items": { "type": "string", "minLength": 1 }
          },
          "attributes": {
            "type": "object",
            "maxProperties": 64,
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
