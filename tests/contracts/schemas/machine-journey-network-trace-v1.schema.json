{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://examples.expanso.io/tests/contracts/schemas/machine-journey-network-trace-v1.schema.json",
  "title": "Expanso machine journey raw network trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceVersion",
    "contractId",
    "contractSha256",
    "subjectSha",
    "environmentId",
    "trialId",
    "taskId",
    "requests"
  ],
  "properties": {
    "traceVersion": { "const": "journey-network-trace-v1" },
    "contractId": { "const": "machine-journey-v1" },
    "contractSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "subjectSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "environmentId": { "type": "string", "minLength": 3 },
    "trialId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "requests": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sequence",
          "method",
          "url",
          "status",
          "repositoryPath",
          "responseSha256"
        ],
        "properties": {
          "sequence": { "type": "integer", "minimum": 0 },
          "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "url": { "type": "string", "minLength": 1 },
          "status": { "type": "integer", "minimum": 100, "maximum": 599 },
          "repositoryPath": { "type": "string", "minLength": 1 },
          "responseSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
