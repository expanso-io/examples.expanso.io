{
  "$schema": "./content-policy-v1.schema.json",
  "contractVersion": "1.0.0",
  "gateId": "content-validator-v1",
  "budgets": {
    "catalog-card": { "targetMin": 12, "targetMax": 24, "hardMax": 32 },
    "overview": { "targetMin": 250, "targetMax": 450, "hardMax": 600 },
    "explorer": { "targetMin": 80, "targetMax": 180, "hardMax": 250 },
    "run": { "targetMin": 250, "targetMax": 500, "hardMax": 700 },
    "step": { "targetMin": 120, "targetMax": 300, "hardMax": 450 },
    "troubleshooting": { "targetMin": 40, "targetMax": 120, "hardMax": 180 },
    "reference": { "targetMin": null, "targetMax": null, "hardMax": null }
  },
  "structure": {
    "overviewOpeningHardMax": 80,
    "localNavigationAfterWords": 450,
    "localNavigationAfterHeadings": 8,
    "localNavigationAfterNarrativeBlocks": 12,
    "duplicateBlockMinimumWords": 40
  },
  "actionHeadingPatterns": [
    "get started",
    "run",
    "try",
    "explore",
    "download",
    "copy"
  ],
  "placeholderPhrases": [
    "coming soon",
    "content coming soon",
    "to be added",
    "placeholder content"
  ],
  "readinessVocabulary": {
    "executionStatuses": [
      "offline-runnable",
      "requires-integration",
      "architecture-only"
    ],
    "operationalEvidenceStatuses": [
      "not-assessed",
      "component-tested",
      "operating-envelope-tested"
    ],
    "forbiddenPatterns": [
      "\\bproduction[- ]ready\\b",
      "\\bproduction[- ]hardened\\b",
      "\\benterprise[- ]ready\\b"
    ]
  },
  "archetypeRequirements": {
    "catalog-card": {
      "requiredFrontmatter": ["title"],
      "requiredHeadingPatterns": [],
      "requiredComponentGroups": []
    },
    "overview": {
      "requiredFrontmatter": [
        "title",
        "executionStatus",
        "operationalEvidence",
        "difficulty",
        "verificationDate",
        "expectedTime"
      ],
      "requiredHeadingPatterns": [
        "get started",
        "pipeline",
        "limitations and assumptions",
        "related examples"
      ],
      "requiredComponentGroups": []
    },
    "explorer": {
      "requiredFrontmatter": [
        "title",
        "executionStatus",
        "operationalEvidence"
      ],
      "requiredHeadingPatterns": ["how to use", "limitations"],
      "requiredComponentGroups": [
        ["ExplorerV2", "DataPipelineExplorer", "ProgressivePipelineExplorer"]
      ]
    },
    "run": {
      "requiredFrontmatter": [
        "title",
        "executionStatus",
        "operationalEvidence"
      ],
      "requiredHeadingPatterns": [
        "prerequisites",
        "run",
        "expected output",
        "cleanup",
        "common failures"
      ],
      "requiredComponentGroups": []
    },
    "step": {
      "requiredFrontmatter": ["title"],
      "requiredHeadingPatterns": [],
      "requiredComponentGroups": []
    },
    "troubleshooting": {
      "requiredFrontmatter": ["title"],
      "requiredHeadingPatterns": [],
      "requiredComponentGroups": []
    },
    "reference": {
      "requiredFrontmatter": ["title"],
      "requiredHeadingPatterns": [],
      "requiredComponentGroups": []
    }
  },
  "componentContracts": {
    "Button": { "mode": "children", "textProps": ["aria-label", "title"] },
    "CodeBlock": {
      "mode": "opaque-narrative-free",
      "textProps": ["title"]
    },
    "CatalogExplorer": {
      "mode": "opaque-narrative-free",
      "textProps": ["description", "title"]
    },
    "CopyPipelineButton": {
      "mode": "opaque-narrative-free",
      "textProps": ["label"]
    },
    "DataPipelineExplorer": {
      "mode": "opaque-narrative-free",
      "textProps": [],
      "importedTextProps": {
        "stages": {
          "narrativeKeys": ["title", "description"],
          "visibleTextKeys": ["title", "description", "content"]
        }
      }
    },
    "ExplorerV2": {
      "mode": "opaque-narrative-free",
      "textProps": [],
      "importedTextProps": {
        "stages": {
          "narrativeKeys": ["title", "description"],
          "visibleTextKeys": ["title", "description", "content"]
        }
      }
    },
    "ExampleHeader": {
      "mode": "opaque-narrative-free",
      "textProps": ["eyebrow", "outcome", "title"]
    },
    "ExampleSurface": {
      "mode": "children",
      "textProps": ["description", "title"]
    },
    "Limitations": {
      "mode": "children",
      "textProps": ["title"]
    },
    "SystemBoundary": {
      "mode": "opaque-narrative-free",
      "textProps": ["title"],
      "importedTextProps": {
        "nodes": {
          "narrativeKeys": ["label", "location"],
          "visibleTextKeys": ["label", "location"]
        },
        "flows": {
          "narrativeKeys": ["payload"],
          "visibleTextKeys": ["payload"]
        }
      }
    },
    "Details": { "mode": "children", "textProps": ["summary"] },
    "ExplorerSection": {
      "mode": "children",
      "textProps": ["title", "description"]
    },
    "ProgressivePipelineExplorer": {
      "mode": "opaque-narrative-free",
      "textProps": [],
      "importedTextProps": {
        "stages": {
          "narrativeKeys": ["title", "description"],
          "visibleTextKeys": ["title", "description", "content"]
        }
      }
    },
    "TabItem": { "mode": "children", "textProps": ["label"] },
    "Tabs": { "mode": "children", "textProps": [] }
  },
  "intrinsicTextProps": ["alt", "title"]
}
